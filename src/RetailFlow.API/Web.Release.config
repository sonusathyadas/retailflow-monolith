<?xml version="1.0" encoding="utf-8"?>
<!-- Web.config transform applied during Release builds / Azure deployment -->
<configuration xmlns:xdt="http://schemas.microsoft.com/XML-Document-Transform">

  <appSettings>
    <!-- Override JWT secret from Azure App Service environment variable -->
    <add key="Jwt:Secret"
         value="#{JWT_SECRET}#"
         xdt:Transform="SetAttributes"
         xdt:Locator="Match(key)" />
    <add key="Environment"
         value="Production"
         xdt:Transform="SetAttributes"
         xdt:Locator="Match(key)" />
  </appSettings>

  <connectionStrings>
    <!-- Azure SQL -->
    <add name="RetailFlowDb"
         connectionString="#{AZURE_SQL_CONNECTION_STRING}#"
         providerName="System.Data.SqlClient"
         xdt:Transform="SetAttributes"
         xdt:Locator="Match(name)" />
    <!-- Azure Cosmos DB (Mongo API) -->
    <add name="MongoDb"
         connectionString="#{COSMOS_DB_CONNECTION_STRING}#"
         xdt:Transform="SetAttributes"
         xdt:Locator="Match(name)" />
    <!-- Azure Cache for Redis -->
    <add name="Redis"
         connectionString="#{REDIS_CONNECTION_STRING}#"
         xdt:Transform="SetAttributes"
         xdt:Locator="Match(name)" />
    <!-- Azure Service Bus -->
    <add name="RabbitMQ"
         connectionString="#{SERVICE_BUS_CONNECTION_STRING}#"
         xdt:Transform="SetAttributes"
         xdt:Locator="Match(name)" />
  </connectionStrings>

  <system.web>
    <compilation xdt:Transform="RemoveAttributes(debug)" />
    <customErrors mode="RemoteOnly" xdt:Transform="SetAttributes" />
  </system.web>

</configuration>
